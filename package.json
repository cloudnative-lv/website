{
  "name": "website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:unit": "node --test src/artifacts/*.test.js",
    "validate:i18n": "node scripts/validate-translations.mjs",
    "validate:events": "node scripts/validate-events.mjs",
    "validate": "npm run lint && npm run validate:i18n && npm run validate:events && npm run test:unit",
    "generate:artifacts": "node scripts/generate-artifacts.mjs",
    "prerender": "node scripts/prerender.mjs",
    "import:eventbrite": "node --env-file-if-exists=.env scripts/eventbrite-attendees.mjs",
    "import:attendees": "node --env-file-if-exists=.env scripts/import-attendees.mjs",
    "import:linkedin": "node --env-file-if-exists=.env scripts/import-linkedin.mjs",
    "import:linkedin-events": "node --env-file-if-exists=.env scripts/import-linkedin-events.mjs",
    "import:ocg": "node --env-file-if-exists=.env scripts/import-ocg.mjs",
    "import:subscribers": "node --env-file-if-exists=.env scripts/import-subscribers.mjs",
    "report:subscribers": "node --env-file-if-exists=.env scripts/report-subscribers.mjs",
    "report:feedback": "node --env-file-if-exists=.env scripts/report-feedback.mjs",
    "crm:cleanup": "node --env-file-if-exists=.env scripts/crm-cleanup.mjs",
    "rebuild": "node --env-file-if-exists=.env scripts/rebuild.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.49.0",
    "@rollup/plugin-yaml": "^5.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "js-yaml": "^4.2.0",
    "postcss": "^8.5.6",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4",
    "wordcloud": "^1.2.3"
  }
}
