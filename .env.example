# Cloudflare subscribe Worker endpoint. When set, the subscribe form POSTs
# { email } here; when empty, it falls back to opening the CNCF/OCG group page.
# In CI this comes from the repo variable SUBSCRIBE_ENDPOINT (see deploy.yml).
VITE_SUBSCRIBE_ENDPOINT=

# Cloudflare feedback Worker endpoint for the (unlisted) per-event feedback form.
# In CI this comes from the repo variable FEEDBACK_ENDPOINT (see deploy.yml).
VITE_FEEDBACK_ENDPOINT=

# --- Local ops (npm run import:eventbrite / import:attendees) — copy to .env ---

# Eventbrite API — Account Settings → Developer links → API Keys → "Private token"
EVENTBRITE_TOKEN=

# Cloudflare — the account that owns the cloudnative-lv R2 bucket
CLOUDFLARE_ACCOUNT_ID=2206fc831247e31fb22b657089145789
R2_BUCKET=cloudnative-lv

# Optional: a scoped API token so wrangler runs non-interactively (R2 read/write).
# Otherwise run `wrangler login` once.
# CLOUDFLARE_API_TOKEN=
