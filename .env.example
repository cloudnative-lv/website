# --- Local ops (npm run import:eventbrite / import:attendees) — copy to .env ---

# Eventbrite API — Account Settings → Developer links → API Keys → "Private token"
EVENTBRITE_TOKEN=

# Cloudflare — the account that owns the cloudnative-lv R2 bucket
CLOUDFLARE_ACCOUNT_ID=2206fc831247e31fb22b657089145789
R2_BUCKET=cloudnative-lv

# Optional: a scoped API token so wrangler runs non-interactively (R2 read/write).
# Otherwise run `wrangler login` once.
# CLOUDFLARE_API_TOKEN=
