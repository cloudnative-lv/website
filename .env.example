# Local ops config — copy to .env (gitignored). Never commit real values.

# Eventbrite API — Account Settings → Developer links → API Keys → "Private token"
EVENTBRITE_TOKEN=

# Cloudflare — the account that owns the cloudnative-lv R2 bucket
CLOUDFLARE_ACCOUNT_ID=2206fc831247e31fb22b657089145789
R2_BUCKET=cloudnative-lv

# R2 S3 API (preferred read/write path — cache-immune, see scripts/lib/s3.mjs).
# Create at: R2 → Manage R2 API Tokens → Create API token (Object Read & Write).
# That gives an Access Key ID + Secret Access Key; the endpoint is shown there too.
R2_ENDPOINT=https://2206fc831247e31fb22b657089145789.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The raw R2 API token string (optional — the ops use the access key / secret above).
R2_TOKEN=

# wrangler fallback (used only when the R2 S3 keys above are absent): a scoped API
# token so wrangler runs non-interactively, else run `wrangler login` once.
# CLOUDFLARE_API_TOKEN=
