# Cloudflare subscribe Worker endpoint. When set, the subscribe form POSTs
# { email } here; when empty, it falls back to opening the CNCF/OCG group page.
# In CI this comes from the repo variable SUBSCRIBE_ENDPOINT (see deploy.yml).
VITE_SUBSCRIBE_ENDPOINT=

# Cloudflare feedback Worker endpoint for the (unlisted) per-event feedback form.
# In CI this comes from the repo variable FEEDBACK_ENDPOINT (see deploy.yml).
VITE_FEEDBACK_ENDPOINT=
