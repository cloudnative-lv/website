{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Server",
      "type": "npm",
      "script": "dev",
      "problemMatcher": [],
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Build",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Preview",
      "type": "npm",
      "script": "preview",
      "problemMatcher": [],
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Install Dependencies",
      "type": "npm",
      "script": "install",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": ["$eslint-stylish"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Validate",
      "type": "npm",
      "script": "validate",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "E2E Tests",
      "type": "npm",
      "script": "test:e2e",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["Build"]
    },
    {
      "label": "E2E Tests (Headed)",
      "type": "npm",
      "script": "test:e2e:headed",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["Build"]
    },
    {
      "label": "E2E Tests (UI Mode)",
      "type": "npm",
      "script": "test:e2e:ui",
      "problemMatcher": [],
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["Build"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Show E2E Report",
      "type": "shell",
      "command": "npx playwright show-report",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },

    {
      "label": "Ops: Import Eventbrite attendees",
      "type": "npm",
      "script": "import:eventbrite",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Import LinkedIn followers",
      "type": "npm",
      "script": "import:linkedin",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Import LinkedIn event attendees",
      "type": "npm",
      "script": "import:linkedin-events",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Import OCG members",
      "type": "npm",
      "script": "import:ocg",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Import attendees (CSV → event roster)",
      "type": "shell",
      "command": "npm run import:attendees -- --event ${input:eventSlug} --source ${input:sourceName} ${input:csvPath}",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Import subscribers (CSV → CRM)",
      "type": "shell",
      "command": "npm run import:subscribers -- --source ${input:sourceName} ${input:csvPath}",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Rebuild CRM from event rosters",
      "type": "shell",
      "command": "npm run import:subscribers -- --from-r2-attendees",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Report subscribers / CRM",
      "type": "npm",
      "script": "report:subscribers",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Report feedback (digest)",
      "type": "npm",
      "script": "report:feedback",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: CRM cleanup (vs NetHunt)",
      "type": "npm",
      "script": "crm:cleanup",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    },
    {
      "label": "Ops: Rebuild CRM + rosters + reports (one pass)",
      "type": "npm",
      "script": "rebuild",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    }
  ],
  "inputs": [
    { "id": "eventSlug", "type": "promptString", "description": "Event slug (e.g. meetup-006-...)" },
    { "id": "csvPath", "type": "promptString", "description": "Path to the CSV export (e.g. data/list.csv)" },
    { "id": "sourceName", "type": "promptString", "description": "Source tag (eventbrite | ocg | zoho | manual …)", "default": "csv" }
  ]
}
